							"value": "25",
							"type": "text"
						},
						{
							"key": "preBuiltPriceCents",
							"value": "899900",
							"type": "text",
							"description": "₹8,999 in cents"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/api/projects/upload",
					"host": ["{{baseUrl}}"],
					"path": ["api", "projects", "upload"]
				},
				"description": "Create project with all possible fields and file uploads"
			},
			"response": []
		},
		{
			"name": "5. Test Validation - Too Many Images",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "images",
							"type": "file",
							"src": [],
							"description": "Add MORE than 5 images to test validation"
						},
						{
							"key": "title",
							"value": "Test Validation Project",
							"type": "text"
						},
						{
							"key": "category",
							"value": "ELECTRONICS",
							"type": "text"
						},
						{
							"key": "description",
							"value": "Testing validation for too many images",
							"type": "text"
						},
						{
							"key": "difficulty",
							"value": "BEGINNER",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/api/projects/upload",
					"host": ["{{baseUrl}}"],
					"path": ["api", "projects", "upload"]
				},
				"description": "Should fail with error: 'Maximum 5 images allowed'"
			},
			"response": []
		},
		{
			"name": "6. Test Validation - Missing Required Fields",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "title",
