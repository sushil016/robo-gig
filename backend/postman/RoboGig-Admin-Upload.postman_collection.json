{
	"info": {
		"_postman_id": "robogig-admin-upload-collection",
		"name": "RoboGig - Admin Project Upload",
		"description": "Collection for testing admin project creation with Azure Blob Storage uploads",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{adminToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "1. Auth - Login as Admin",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"if (response.success && response.data.accessToken) {",
							"    pm.collectionVariables.set('adminToken', response.data.accessToken);",
							"    console.log('✅ Admin token saved:', response.data.accessToken.substring(0, 20) + '...');",
							"} else {",
							"    console.log('❌ Login failed');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"admin@robogig.com\",\n  \"password\": \"Admin@123\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				},
				"description": "Login with admin credentials to get access token"
			},
			"response": []
		},
		{
			"name": "2. Create Project - Minimal (No Files)",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "title",
							"value": "Arduino Smart Home System",
							"type": "text"
						},
						{
							"key": "category",
							"value": "IOT",
							"type": "text",
							"description": "Options: IOT, ROBOTICS, ELECTRONICS, PROGRAMMING, MECHANICAL, EDUCATIONAL"
						},
						{
							"key": "description",
							"value": "Build a complete IoT-based smart home automation system using Arduino. Control lights, fans, and appliances remotely via smartphone app. Learn about sensors, relays, and wireless communication protocols.",
							"type": "text"
						},
						{
							"key": "difficulty",
							"value": "INTERMEDIATE",
							"type": "text",
							"description": "Options: BEGINNER, INTERMEDIATE, ADVANCED"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/api/projects/upload",
					"host": ["{{baseUrl}}"],
					"path": ["api", "projects", "upload"]
				},
				"description": "Create project with minimal required fields (no file uploads)"
			},
			"response": []
		},
		{
			"name": "3. Create Project - With Images Only",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "images",
							"type": "file",
							"src": [],
							"description": "Add image files (max 5, JPEG/PNG/WebP, max 5MB each)"
						},
						{
							"key": "thumbnail",
							"type": "file",
							"src": [],
							"description": "Add thumbnail image (JPEG/PNG/WebP, max 5MB)"
						},
						{
							"key": "title",
							"value": "Line Following Robot",
							"type": "text"
						},
						{
							"key": "category",
							"value": "ROBOTICS",
							"type": "text"
						},
						{
							"key": "description",
							"value": "Build an autonomous line-following robot using IR sensors and Arduino. Perfect beginner robotics project to learn about sensor integration and motor control.",
							"type": "text"
						},
						{
							"key": "summary",
							"value": "Autonomous robot that follows black lines using IR sensors",
							"type": "text"
						},
						{
							"key": "difficulty",
							"value": "BEGINNER",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/api/projects/upload",
					"host": ["{{baseUrl}}"],
					"path": ["api", "projects", "upload"]
				},
				"description": "Create project with image uploads"
			},
			"response": []
		},
		{
			"name": "4. Create Project - Complete (All Fields)",
			"request": {
